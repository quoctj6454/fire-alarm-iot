<?xml version="1.0" encoding="utf-8"?>
<!--
    ============================================================
    CẢNH BÁO: File này đã được BỌC LẠI để hỗ trợ Bottom Navigation.
    - Root layout mới: ConstraintLayout (nền tối #0D0D1A)
    - layout_realtime: TOÀN BỘ ScrollView cũ — KHÔNG THAY ĐỔI NỘI DUNG
    - layout_analytics: Màn hình Analytics mới (mặc định GONE)
    - BottomNavigationView: Cố định ở đáy màn hình
    ============================================================
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- ============================================================ -->
    <!--  VÙNG NỘI DUNG CHÍNH (chiếm toàn bộ từ top đến trên bottom nav) -->
    <!-- ============================================================ -->

    <!-- ===== LAYOUT REALTIME (Màn hình cũ — NGUYÊN VẸN 100%) ===== -->
    <ScrollView
        android:id="@+id/layout_realtime"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0D0D1A"
        android:fillViewport="true"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ===== HEADER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔥 FIRE ALARM"
                    android:textColor="#FF6B35"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="HỆ THỐNG CẢNH BÁO VÀ CHỮA CHÁY"
                    android:textColor="#88AABBCC"
                    android:textSize="12sp"
                    android:letterSpacing="0.15"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- ===== CARD_SENSORS: Nhiệt độ & Mức khói ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSensors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡  DỮ LIỆU CẢM BIẾN"
                        android:textColor="#AABBCC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="16dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Nhiệt độ -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#12FFFFFF"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="🌡️"
                                android:textSize="36sp" />

                            <TextView
                                android:id="@+id/txtTempValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FF6B35"
                                android:textSize="38sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="°C"
                                android:textColor="#AABBCC"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NHIỆT ĐỘ"
                                android:textColor="#66AABBCC"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="#22FFFFFF"
                            android:layout_marginHorizontal="12dp" />

                        <!-- Mức khói -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#12FFFFFF"
                            android:padding="16dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="💨"
                                android:textSize="36sp" />

                            <TextView
                                android:id="@+id/txtSmokeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#7EC8E3"
                                android:textSize="38sp"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ppm"
                                android:textColor="#AABBCC"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MỨC KHÓI"
                                android:textColor="#66AABBCC"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            android:letterSpacing="0.15"
                            android:text="🛡️  TRẠNG THÁI AN TOÀN"
                            android:textColor="#AABBCC"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:id="@+id/layoutSafetyBg"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:background="@drawable/bg_safe_card">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/txtSafetyIcon"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="✅"
                                    android:textSize="30sp" />

                                <TextView
                                    android:id="@+id/txtSafetyStatus"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:letterSpacing="0.15"
                                    android:text="AN TOÀN"
                                    android:textColor="#FFFFFF"
                                    android:textSize="28sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CARD_CAMERA_STREAM: Camera / Video stream trực tiếp ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_camera_stream"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#0F0F1E"
                app:cardCornerRadius="16dp"
                app:cardElevation="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Header: tiêu đề + badge LIVE -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📷  CAMERA TRỰC TIẾP"
                            android:textColor="#AABBCC"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.15" />

                        <TextView
                            android:id="@+id/txt_stream_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="● LIVE"
                            android:textColor="#4CAF50"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="6dp"
                            android:paddingVertical="2dp"
                            android:background="#1A4CAF50" />
                    </LinearLayout>

                    <!-- Khung hiển thị stream — chiều cao 200dp (~16:9) -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="200dp">

                        <!-- ImageView hiển thị từng JPEG frame của luồng MJPEG -->
                        <ImageView
                            android:id="@+id/img_camera_stream"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="#000000"
                            android:scaleType="fitCenter"
                            android:adjustViewBounds="true"
                            android:visibility="gone" />

                        <!-- Placeholder hiển thị khi chưa kết nối -->
                        <LinearLayout
                            android:id="@+id/layout_stream_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#0A0A14"
                            android:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📷"
                                android:textSize="42sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đang kết nối camera..."
                                android:textColor="#44AABBCC"
                                android:textSize="13sp"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </FrameLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CARD_ENV_WARNING: Cảnh báo môi trường ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEnvWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️  CẢNH BÁO MÔI TRƯỜNG"
                        android:textColor="#AABBCC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#12FFFFFF"
                        android:padding="14dp">

                        <TextView
                            android:id="@+id/imgWarningIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✅"
                            android:textSize="28sp"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/txtEnvWarning"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chỉ số ổn định"
                            android:textColor="#E8F5E9"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== CARD_SAFETY_STATUS: Trạng thái an toàn ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardSafetyStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp">

            </androidx.cardview.widget.CardView>

            <!-- ===== CARD_PUMP_STATUS: Trạng thái máy bơm ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPumpStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💧  MÁY BƠM CHỮA CHÁY"
                        android:textColor="#AABBCC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="#12FFFFFF"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/txtPumpIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⭕"
                            android:textSize="32sp"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TRẠNG THÁI BƠM"
                                android:textColor="#66AABBCC"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/txtPumpStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ĐANG TẮT"
                                android:textColor="#EF9A9A"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtPumpBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" TẮT "
                            android:background="#33EF9A9A"
                            android:textColor="#EF9A9A"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ===== BUTTON CONTROL: Bật/Tắt bơm thủ công ===== -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardControl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1A1A2E"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎛️  ĐIỀU KHIỂN THỦ CÔNG"
                        android:textColor="#AABBCC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="14dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTogglePump"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:text="💧  BẬT BƠM THỦ CÔNG"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        app:backgroundTint="#FF6B35"
                        app:cornerRadius="16dp"
                        app:icon="@android:drawable/ic_media_play"
                        app:iconGravity="textStart"
                        app:iconTint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚙️  Nhấn để bật/tắt máy bơm. Hệ thống tự động điều khiển khi phát hiện lửa."
                        android:textColor="#55AABBCC"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:layout_marginTop="10dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- ============================================================ -->
    <!--  LAYOUT ANALYTICS (Màn hình mới — Mặc định ẩn GONE)        -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/layout_analytics"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:background="#0D0D1A"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- HEADER Analytics -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📊 LỊCH SỬ SỰ KIỆN"
                android:textColor="#FF6B35"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HỆ THỐNG"
                android:textColor="#44AABBCC"
                android:textSize="10sp"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <!-- ===== CARD SUMMARY: Tổng hợp thống kê ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📈  TỔNG QUAN HỆ THỐNG"
                    android:textColor="#AABBCC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="16dp" />

                <!-- 2 card thống kê side-by-side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- ===== CARD CẢNH BÁO ===== -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#12FFFFFF"
                        android:padding="14dp"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="26sp" />

                        <!-- Tổng cảnh báo mọi thời gian -->
                        <TextView
                            android:id="@+id/txtTotalWarnings"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#FF6B35"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỔNG CẢNH BÁO"
                            android:textColor="#66AABBCC"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="2dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#22FFFFFF"
                            android:layout_marginVertical="10dp" />

                        <!-- Cảnh báo hôm nay -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtWarningsToday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#FF6B35"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HÔM NAY"
                            android:textColor="#55AABBCC"
                            android:textSize="9sp"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <!-- ===== CARD CHÁY ===== -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="#12FFFFFF"
                        android:padding="14dp"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔥"
                            android:textSize="26sp" />

                        <!-- Tổng cháy mọi thời gian -->
                        <TextView
                            android:id="@+id/txtTotalFires"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="#EF5350"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TỔNG VỤ CHÁY"
                            android:textColor="#66AABBCC"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="2dp" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#22FFFFFF"
                            android:layout_marginVertical="10dp" />

                        <!-- Cháy hôm nay -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📅"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/txtFiresToday"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textColor="#EF5350"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HÔM NAY"
                            android:textColor="#55AABBCC"
                            android:textSize="9sp"
                            android:letterSpacing="0.1"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Thời gian sự kiện gần nhất -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="#0AFFFFFF"
                    android:padding="12dp"
                    android:layout_marginTop="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐  Sự kiện gần nhất: "
                        android:textColor="#66AABBCC"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/txtLastEventTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="#AABBCC"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== THANH TAB LỌC SỰ KIỆN ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabAllEvents"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="Tất cả"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="#FF6B35"
                app:cornerRadius="10dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabFireOnly"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="🔥 Cháy"
                android:textColor="#AABBCC"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                app:backgroundTint="#1A1A2E"
                app:cornerRadius="10dp"
                app:strokeColor="#33FFFFFF"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTabWarningOnly"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_weight="1"
                android:text="⚠️ Báo"
                android:textColor="#AABBCC"
                android:textSize="12sp"
                app:backgroundTint="#1A1A2E"
                app:cornerRadius="10dp"
                app:strokeColor="#33FFFFFF"
                app:strokeWidth="1dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- ===== HEADER DANH SÁCH SỰ KIỆN + PHÂN TRANG ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp">

            <!-- Dòng 1: Label + ProgressBar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NHẬT KÝ SỰ KIỆN"
                    android:textColor="#55AABBCC"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.2" />

                <ProgressBar
                    android:id="@+id/progressEvents"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:visibility="gone"
                    android:indeterminateTint="#FF6B35" />
            </LinearLayout>

            <!-- Dòng 2: Nút phân trang -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPagePrev"
                    android:layout_width="36dp"
                    android:layout_height="30dp"
                    android:text="◀"
                    android:textSize="11sp"
                    android:textColor="#AABBCC"
                    android:enabled="false"
                    app:backgroundTint="#1E1E30"
                    app:cornerRadius="8dp"
                    app:strokeColor="#33FFFFFF"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

                <TextView
                    android:id="@+id/txtPageInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Trang 1/1  (0 sự kiện)"
                    android:textColor="#77AABBCC"
                    android:textSize="11sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPageNext"
                    android:layout_width="36dp"
                    android:layout_height="30dp"
                    android:text="▶"
                    android:textSize="11sp"
                    android:textColor="#AABBCC"
                    android:enabled="false"
                    app:backgroundTint="#1E1E30"
                    app:cornerRadius="8dp"
                    app:strokeColor="#33FFFFFF"
                    app:strokeWidth="1dp"
                    style="@style/Widget.MaterialComponents.Button"
                    android:paddingStart="0dp"
                    android:paddingEnd="0dp" />

            </LinearLayout>
        </LinearLayout>

        <!-- ===== RECYCLERVIEW DANH SÁCH SỰ KIỆN ===== -->
        <!-- weight=1 giúp RecyclerView chiếm hết phần còn lại -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEvents"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- ============================================================ -->
    <!--  BOTTOM NAVIGATION BAR (Cố định ở đáy)                     -->
    <!-- ============================================================ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#12131F"
        app:itemIconTint="@null"
        app:itemTextColor="#AABBCC"

        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bottom_nav"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>